# Resend
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Email de envío (debe estar verificado en tu dominio Resend)
FROM_EMAIL=ventas@mercadolimpio.ar
FROM_NAME=Mercado Limpio

# A dónde llegan las respuestas de los proveedores
REPLY_TO=distribuidoramercadolimpio@gmail.com

# Puerto (Railway lo asigna automáticamente, no hace falta tocarlo)
PORT=3000

# Contraseña para acceder a la app (opcional pero recomendado)
# Si no la ponés, la app es de acceso libre
APP_PASSWORD=tu_contraseña_secreta

# Tamaño máximo de adjuntos en MB (por defecto 25)
MAX_MB=25
